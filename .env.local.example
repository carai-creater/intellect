# このファイルをコピーして .env.local を作成し、値を埋めてください。
# .env.local は git にコミットしないでください（.gitignore に含まれています）。

# アプリの表示名（省略時は "Intellect"）。任意の名前に変更できます。
# NEXT_PUBLIC_APP_NAME=My App

# Supabase（サーバー専用・ブラウザに送信されません）
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=contexts

# Gemini（サーバー専用・ブラウザに送信されません）
GEMINI_API_KEY=your_gemini_api_key
